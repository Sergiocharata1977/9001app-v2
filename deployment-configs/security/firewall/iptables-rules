#!/bin/bash

# Firewall Rules for 9001app-v2
# This script configures iptables rules for the application

# Flush existing rules
iptables -F
iptables -X
iptables -t nat -F
iptables -t nat -X
iptables -t mangle -F
iptables -t mangle -X

# Set default policies
iptables -P INPUT DROP
iptables -P FORWARD DROP
iptables -P OUTPUT ACCEPT

# Allow loopback traffic
iptables -A INPUT -i lo -j ACCEPT
iptables -A OUTPUT -o lo -j ACCEPT

# Allow established connections
iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT

# Allow SSH (port 22)
iptables -A INPUT -p tcp --dport 22 -m state --state NEW -j ACCEPT

# Allow HTTP (port 80)
iptables -A INPUT -p tcp --dport 80 -m state --state NEW -j ACCEPT

# Allow HTTPS (port 443)
iptables -A INPUT -p tcp --dport 443 -m state --state NEW -j ACCEPT

# Allow backend API (port 3000) - only from internal network
iptables -A INPUT -p tcp --dport 3000 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT
iptables -A INPUT -p tcp --dport 3000 -s 172.16.0.0/12 -m state --state NEW -j ACCEPT
iptables -A INPUT -p tcp --dport 3000 -s 192.168.0.0/16 -m state --state NEW -j ACCEPT

# Allow Prometheus (port 9090) - only from monitoring network
iptables -A INPUT -p tcp --dport 9090 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow Grafana (port 3002) - only from monitoring network
iptables -A INPUT -p tcp --dport 3002 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow Elasticsearch (port 9200) - only from internal network
iptables -A INPUT -p tcp --dport 9200 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow Kibana (port 5601) - only from monitoring network
iptables -A INPUT -p tcp --dport 5601 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow Redis (port 6379) - only from internal network
iptables -A INPUT -p tcp --dport 6379 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow MongoDB (port 27017) - only from internal network
iptables -A INPUT -p tcp --dport 27017 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow Node Exporter (port 9100) - only from monitoring network
iptables -A INPUT -p tcp --dport 9100 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Allow Alertmanager (port 9093) - only from monitoring network
iptables -A INPUT -p tcp --dport 9093 -s 10.0.0.0/8 -m state --state NEW -j ACCEPT

# Rate limiting for HTTP/HTTPS
iptables -A INPUT -p tcp --dport 80 -m limit --limit 100/minute --limit-burst 200 -j ACCEPT
iptables -A INPUT -p tcp --dport 443 -m limit --limit 100/minute --limit-burst 200 -j ACCEPT

# Rate limiting for SSH
iptables -A INPUT -p tcp --dport 22 -m limit --limit 5/minute --limit-burst 10 -j ACCEPT

# Block common attack ports
iptables -A INPUT -p tcp --dport 23 -j DROP  # Telnet
iptables -A INPUT -p tcp --dport 21 -j DROP  # FTP
iptables -A INPUT -p tcp --dport 25 -j DROP  # SMTP
iptables -A INPUT -p tcp --dport 1433 -j DROP  # SQL Server
iptables -A INPUT -p tcp --dport 3306 -j DROP  # MySQL
iptables -A INPUT -p tcp --dport 5432 -j DROP  # PostgreSQL

# Block ICMP flood
iptables -A INPUT -p icmp -m limit --limit 1/second --limit-burst 4 -j ACCEPT
iptables -A INPUT -p icmp -j DROP

# Block invalid packets
iptables -A INPUT -m state --state INVALID -j DROP

# Log dropped packets
iptables -A INPUT -j LOG --log-prefix "IPTABLES-DROPPED: "
iptables -A INPUT -j DROP

# Save rules
iptables-save > /etc/iptables/rules.v4

echo "Firewall rules configured successfully"