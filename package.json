{
  "name": "agent-coordinator",
  "version": "1.0.0",
  "description": "Coordinador de agentes para proyecto ISO 9001 con Testing Completo",
  "main": "dist/coordinator.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/coordinator.js",
    "dev": "echo 'Coordinador de agentes deshabilitado temporalmente'",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && npm run dev",
    "security": "node dist/coordinator.js security",
    "structure": "node dist/coordinator.js structure",
    "typescript": "node dist/coordinator.js typescript",
    "api": "node dist/coordinator.js api",
    "full": "node dist/coordinator.js full-migration",
    "web": "node dist/coordinator.js web",
    "test": "node scripts/test-runner.js",
    "test:frontend": "node scripts/test-runner.js --frontend-only",
    "test:backend": "node scripts/test-runner.js --backend-only",
    "test:security": "node scripts/test-runner.js --security-only",
    "test:performance": "node scripts/test-runner.js --performance-only",
    "debugbot:analyze": "node scripts/test-runner.js --no-performance",
    "debugbot:full": "node scripts/test-runner.js",
    "debugbot:quick": "node scripts/test-runner.js --no-security --no-performance",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "clean": "rm -rf node_modules frontend/node_modules backend/node_modules",
    "clean:coverage": "rm -rf frontend/coverage backend/coverage test-reports",
    "setup:testing": "chmod +x scripts/test-runner.js"
  },
  "dependencies": {
    "@types/node": "^20.0.0",
    "axios": "^1.4.0",
    "chalk": "^5.0.0",
    "commander": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/commander": "^2.12.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "ts-node": "^10.9.0"
  }
}
