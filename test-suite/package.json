{
  "name": "9001app-v2-test-suite",
  "version": "1.0.0",
  "description": "Suite completa de tests para la migración de Turso a MongoDB Atlas",
  "main": "index.js",
  "scripts": {
    "test": "bash scripts/run-all-tests.sh",
    "test:unit": "bash scripts/run-all-tests.sh --unit-only",
    "test:integration": "bash scripts/run-all-tests.sh --integration-only",
    "test:e2e": "bash scripts/run-all-tests.sh --e2e-only",
    "test:performance": "bash scripts/run-all-tests.sh --performance-only",
    "test:security": "bash scripts/run-all-tests.sh --security-only",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false",
    "e2e:run": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:debug": "playwright test --debug",
    "performance:load": "k6 run performance/load/concurrent-users.test.js",
    "performance:stress": "k6 run performance/stress/extreme-load.test.js",
    "performance:memory": "k6 run performance/stress/memory-leak.test.js",
    "security:scan": "npm run test:security",
    "reports": "node scripts/generate-consolidated-report.js",
    "cleanup": "bash scripts/cleanup-test-data.sh",
    "setup": "bash scripts/setup-test-environment.sh"
  },
  "keywords": [
    "testing",
    "quality-assurance",
    "mongodb",
    "migration",
    "iso-9001",
    "e2e",
    "performance",
    "security"
  ],
  "author": "Tester de Calidad Senior",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.35.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^2.0.12",
    "artillery": "^2.0.0",
    "cypress": "^12.17.0",
    "jest": "^29.6.0",
    "jest-junit": "^16.0.0",
    "k6": "^0.45.0",
    "mongodb-memory-server": "^9.1.0",
    "puppeteer": "^20.8.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0",
    "vitest": "^0.34.0"
  },
  "dependencies": {
    "axios": "^1.4.0",
    "bcrypt": "^5.1.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/config/test-environment.js"],
    "collectCoverageFrom": [
      "../backend/**/*.{js,ts}",
      "../frontend/src/**/*.{js,ts,jsx,tsx}",
      "!**/node_modules/**",
      "!**/*.test.{js,ts,jsx,tsx}"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}