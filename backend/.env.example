# ============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# ============================================================================

# Puerto del servidor
PORT=3000

# Ambiente de ejecución
NODE_ENV=development

# URL del frontend
FRONTEND_URL=http://localhost:5173

# ============================================================================
# CONFIGURACIÓN DE MONGODB ATLAS
# ============================================================================

# URI de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/isoflow4?retryWrites=true&w=majority

# Nombre de la base de datos
MONGODB_DATABASE=isoflow4

# Configuración del pool de conexiones
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=45000

# ============================================================================
# CONFIGURACIÓN DE REDIS
# ============================================================================

# Host de Redis
REDIS_HOST=localhost

# Puerto de Redis
REDIS_PORT=6379

# Contraseña de Redis (opcional)
REDIS_PASSWORD=

# Base de datos de Redis
REDIS_DATABASE=0

# ============================================================================
# CONFIGURACIÓN DE OPENAI
# ============================================================================

# API Key de OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# ID de organización de OpenAI
OPENAI_ORGANIZATION=org-your-organization-id

# ============================================================================
# CONFIGURACIÓN DE ANTHROPIC (OPCIONAL)
# ============================================================================

# API Key de Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================================================

# Clave secreta para JWT
JWT_SECRET=your-super-secret-jwt-key-here

# Tiempo de expiración del token JWT
JWT_EXPIRES_IN=24h

# Tiempo de expiración del refresh token
JWT_REFRESH_EXPIRES_IN=7d

# Clave para encriptación de datos sensibles
ENCRYPTION_KEY=your-32-character-encryption-key

# ============================================================================
# CONFIGURACIÓN DE LOGGING
# ============================================================================

# Nivel de logging
LOG_LEVEL=debug

# Directorio de logs
LOG_DIR=logs

# ============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# ============================================================================

# Ventana de tiempo para rate limiting (en ms)
RATE_LIMIT_WINDOW_MS=900000

# Número máximo de requests por ventana
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# CONFIGURACIÓN DE CORS
# ============================================================================

# Orígenes permitidos para CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# ============================================================================
# CONFIGURACIÓN DE EMAIL (OPCIONAL)
# ============================================================================

# Servidor SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email de notificaciones
NOTIFICATION_EMAIL=noreply@yourdomain.com

# ============================================================================
# CONFIGURACIÓN DE SLACK (OPCIONAL)
# ============================================================================

# Webhook URL de Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# ============================================================================
# CONFIGURACIÓN DE MONITOREO
# ============================================================================

# Sentry DSN (opcional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# DataDog API Key (opcional)
DATADOG_API_KEY=your-datadog-api-key

# ============================================================================
# CONFIGURACIÓN DE AWS (OPCIONAL)
# ============================================================================

# AWS Access Key ID
AWS_ACCESS_KEY_ID=your-aws-access-key

# AWS Secret Access Key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# AWS Region
AWS_REGION=us-east-1

# S3 Bucket para archivos
S3_BUCKET=your-s3-bucket-name

# ============================================================================
# CONFIGURACIÓN DE ELASTICSEARCH (OPCIONAL)
# ============================================================================

# URL de Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Usuario de Elasticsearch
ELASTICSEARCH_USERNAME=elastic

# Contraseña de Elasticsearch
ELASTICSEARCH_PASSWORD=your-elasticsearch-password

# ============================================================================
# CONFIGURACIÓN DE PROMETHEUS (OPCIONAL)
# ============================================================================

# Puerto para métricas de Prometheus
PROMETHEUS_PORT=9090

# ============================================================================
# CONFIGURACIÓN DE DESARROLLO
# ============================================================================

# Habilitar logs detallados en desarrollo
DEBUG=true

# Habilitar hot reload
HOT_RELOAD=true

# ============================================================================
# CONFIGURACIÓN DE PRODUCCIÓN
# ============================================================================

# Habilitar compresión en producción
ENABLE_COMPRESSION=true

# Habilitar cache en producción
ENABLE_CACHE=true

# Tiempo de vida del cache (en segundos)
CACHE_TTL=300

# ============================================================================
# CONFIGURACIÓN DE BACKUP
# ============================================================================

# Habilitar backups automáticos
ENABLE_BACKUP=true

# Frecuencia de backup (en horas)
BACKUP_FREQUENCY=24

# Retención de backups (en días)
BACKUP_RETENTION=30

# ============================================================================
# CONFIGURACIÓN DE LIMITES
# ============================================================================

# Límite de tamaño de archivo (en bytes)
MAX_FILE_SIZE=10485760

# Límite de requests de IA por día
AI_REQUESTS_DAILY_LIMIT=1000

# Límite de almacenamiento por organización (en bytes)
STORAGE_LIMIT_PER_ORG=1073741824

# ============================================================================
# CONFIGURACIÓN DE FEATURES
# ============================================================================

# Habilitar características de IA
ENABLE_AI_FEATURES=true

# Habilitar sistema RAG
ENABLE_RAG=true

# Habilitar WebSockets
ENABLE_WEBSOCKETS=true

# Habilitar auditoría
ENABLE_AUDIT=true

# ============================================================================
# CONFIGURACIÓN DE INTEGRACIONES
# ============================================================================

# Webhook URL para notificaciones externas
WEBHOOK_URL=https://your-webhook-url.com/notifications

# API Key para integraciones externas
EXTERNAL_API_KEY=your-external-api-key

# ============================================================================
# CONFIGURACIÓN DE TESTING
# ============================================================================

# Base de datos de testing
TEST_MONGODB_URI=mongodb://localhost:27017/isoflow4_test

# Habilitar modo testing
TESTING=false

# ============================================================================
# CONFIGURACIÓN DE CI/CD
# ============================================================================

# Token de GitHub para CI/CD
GITHUB_TOKEN=your-github-token

# URL del webhook de GitHub
GITHUB_WEBHOOK_URL=https://your-domain.com/api/github/webhook

# ============================================================================
# CONFIGURACIÓN DE MONITOREO DE SALUD
# ============================================================================

# Intervalo de health check (en ms)
HEALTH_CHECK_INTERVAL=30000

# Timeout de health check (en ms)
HEALTH_CHECK_TIMEOUT=5000

# ============================================================================
# CONFIGURACIÓN DE MIGRACIONES
# ============================================================================

# Habilitar migraciones automáticas
AUTO_MIGRATE=true

# Habilitar seed automático
AUTO_SEED=false

# ============================================================================
# CONFIGURACIÓN DE CACHE
# ============================================================================

# Tiempo de vida del cache de organizaciones (en ms)
ORG_CACHE_TTL=300000

# Tiempo de vida del cache de agentes (en ms)
AGENT_CACHE_TTL=600000

# Tiempo de vida del cache de documentos (en ms)
DOCUMENT_CACHE_TTL=900000
