    "generate-reports": "node scripts/generate-reports.js",
    "setup-security": "node scripts/setup-security.js",
    "configure-sharding": "node scripts/configure-sharding.js",
    "setup-backup": "node scripts/setup-backup.js",
    "install": "npm install && npm run generate-schemas",
    "build": "npm run validate-schemas && npm run optimize-indexes",
    "deploy": "npm run setup-database && npm run create-performance-indexes",
    "test": "npm run test-performance && npm run validate-compliance",
    "docs": "npm run generate-docs && npm run create-tech-docs",
    "maintenance": "npm run monitor-health && npm run cleanup-old-data",
    "full-setup": "npm run install && npm run build && npm run deploy && npm run test"
