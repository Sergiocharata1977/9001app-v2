  "version": "1.0.0",
  "description": "Esquemas MongoDB optimizados para sistema multi-agente de gestión ISO 9001:2015",
  "main": "index.js",
  "scripts": {
    "generate-schemas": "node scripts/generate-schemas.js",
    "validate-schemas": "node scripts/validate-schemas.js",
    "optimize-indexes": "node scripts/optimize-indexes.js",
    "generate-docs": "node scripts/generate-docs.js",
    "create-performance-indexes": "node scripts/create-performance-indexes.js",
    "validate-relationships": "node scripts/validate-relationships.js",
    "generate-strategies": "node scripts/generate-strategies.js",
