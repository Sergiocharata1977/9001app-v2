{
  "collection": "processes",
  "schema": {
    "name": {
      "type": "string",
      "required": true,
      "trim": true,
      "maxlength": 200,
      "index": true
    },
    "code": {
      "type": "string",
      "required": true,
      "unique": true,
      "trim": true,
      "maxlength": 50,
      "index": true
    },
    "organizationId": {
      "type": "objectId",
      "required": true,
      "ref": "organizations",
      "index": true
    },
    "category": {
      "type": "string",
      "required": true,
      "enum": ["core", "support", "management", "improvement"],
      "index": true
    },
    "description": {
      "type": "string",
      "trim": true,
      "maxlength": 1000
    },
    "version": {
      "type": "string",
      "default": "1.0.0"
    },
    "status": {
      "type": "string",
      "required": true,
      "enum": ["draft", "active", "inactive", "archived"],
      "default": "draft",
      "index": true
    },
    "workflow": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["linear", "parallel", "conditional", "loop"],
          "default": "linear"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "required": true },
              "name": { "type": "string", "required": true },
              "description": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["task", "approval", "notification", "decision", "integration"]
              },
              "assignee": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "enum": ["user", "role", "department", "agent"] },
                  "value": { "type": "string" }
                }
              },
              "duration": { "type": "number" },
              "dependencies": { "type": "array", "items": { "type": "string" } },
              "conditions": {
                "type": "object",
                "properties": {
                  "field": { "type": "string" },
                  "operator": { "type": "string" },
                  "value": { "type": "string" }
                }
              },
              "actions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string" },
                    "config": { "type": "object" }
                  }
                }
              }
            }
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "condition": { "type": "object" },
              "actions": { "type": "array" }
            }
          }
        }
      }
    },
    "kpis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "type": { "type": "string", "enum": ["efficiency", "quality", "time", "cost"] },
          "formula": { "type": "string" },
          "target": { "type": "number" },
          "unit": { "type": "string" },
          "frequency": { "type": "string", "enum": ["daily", "weekly", "monthly", "quarterly"] }
        }
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "probability": { "type": "string", "enum": ["low", "medium", "high"] },
          "impact": { "type": "string", "enum": ["low", "medium", "high"] },
          "mitigation": { "type": "string" }
        }
      }
    },
    "resources": {
      "type": "object",
      "properties": {
        "human": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string" },
              "skills": { "type": "array", "items": { "type": "string" } },
              "quantity": { "type": "number" }
            }
          }
        },
        "equipment": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "specifications": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "materials": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "specifications": { "type": "string" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" }
            }
          }
        }
      }
    },
    "documentation": {
      "type": "object",
      "properties": {
        "procedures": { "type": "array", "items": { "type": "string" } },
        "forms": { "type": "array", "items": { "type": "string" } },
        "records": { "type": "array", "items": { "type": "string" } },
        "instructions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "compliance": {
      "type": "object",
      "properties": {
        "iso9001": {
          "type": "object",
          "properties": {
            "clause": { "type": "string" },
            "requirements": { "type": "array", "items": { "type": "string" } },
            "evidence": { "type": "array", "items": { "type": "string" } }
          }
        },
        "regulations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "requirements": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "executions": { "type": "number", "default": 0 },
        "successRate": { "type": "number", "default": 0 },
        "averageDuration": { "type": "number", "default": 0 },
        "lastExecution": { "type": "date" }
      }
    },
    "createdBy": {
      "type": "objectId",
      "ref": "users",
      "required": true
    },
    "approvedBy": {
      "type": "objectId",
      "ref": "users"
    },
    "approvedAt": {
      "type": "date"
    },
    "createdAt": {
      "type": "date",
      "default": "now"
    },
    "updatedAt": {
      "type": "date",
      "default": "now"
    }
  },
  "indexes": [
    { "name": "name_1", "keys": { "name": 1 } },
    { "name": "code_1", "keys": { "code": 1 }, "unique": true },
    { "name": "organizationId_1", "keys": { "organizationId": 1 } },
    { "name": "category_1", "keys": { "category": 1 } },
    { "name": "status_1", "keys": { "status": 1 } },
    { "name": "organizationId_status_1", "keys": { "organizationId": 1, "status": 1 } },
    { "name": "category_status_1", "keys": { "category": 1, "status": 1 } },
    { "name": "createdBy_1", "keys": { "createdBy": 1 } },
    { "name": "createdAt_1", "keys": { "createdAt": -1 } }
  ],
  "validation": {
    "validator": {
      "$jsonSchema": {
        "bsonType": "object",
        "required": ["name", "code", "organizationId", "category"],
        "properties": {
          "name": {
            "bsonType": "string",
            "minLength": 1,
            "maxLength": 200
          },
          "code": {
            "bsonType": "string",
            "minLength": 1,
            "maxLength": 50
          },
          "organizationId": {
            "bsonType": "objectId"
          },
          "category": {
            "enum": ["core", "support", "management", "improvement"]
          },
          "status": {
            "enum": ["draft", "active", "inactive", "archived"]
          }
        }
      }
    }
  }
}