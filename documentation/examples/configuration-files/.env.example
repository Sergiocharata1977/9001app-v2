# =============================================================================
# CONFIGURACIÓN DE VARIABLES DE ENTORNO - 9001app-v2
# =============================================================================
# Este archivo contiene todas las variables de entorno necesarias para
# configurar el sistema 9001app-v2. Copia este archivo como .env y
# personaliza los valores según tu entorno.

# =============================================================================
# CONFIGURACIÓN DEL SERVIDOR
# =============================================================================

# Entorno de ejecución
NODE_ENV=development

# Puerto del servidor backend
PORT=5000

# Host del servidor
HOST=localhost

# URL base de la aplicación
BASE_URL=http://localhost:5000

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS - MONGODB ATLAS
# =============================================================================

# URI de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/9001app_v2?retryWrites=true&w=majority

# Nombre de la base de datos
MONGODB_DB=9001app_v2

# Opciones de conexión MongoDB
MONGODB_OPTIONS_MAX_POOL_SIZE=10
MONGODB_OPTIONS_SERVER_SELECTION_TIMEOUT_MS=5000
MONGODB_OPTIONS_SOCKET_TIMEOUT_MS=45000
MONGODB_OPTIONS_BUFFER_MAX_ENTRIES=0

# =============================================================================
# CONFIGURACIÓN JWT (JSON WEB TOKENS)
# =============================================================================

# Clave secreta para firmar JWT (cambiar en producción)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Tiempo de expiración del token de acceso
JWT_EXPIRES_IN=24h

# Tiempo de expiración del refresh token
JWT_REFRESH_EXPIRES_IN=7d

# Algoritmo de firma JWT
JWT_ALGORITHM=HS256

# =============================================================================
# CONFIGURACIÓN CORS (CROSS-ORIGIN RESOURCE SHARING)
# =============================================================================

# Orígenes permitidos para CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Credenciales CORS
CORS_CREDENTIALS=true

# Métodos HTTP permitidos
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Headers permitidos
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# =============================================================================
# CONFIGURACIÓN DE LOGGING
# =============================================================================

# Nivel de logging
LOG_LEVEL=info

# Archivo de log
LOG_FILE=logs/app.log

# Formato de log
LOG_FORMAT=combined

# Rotación de logs
LOG_ROTATION_MAX_SIZE=10m
LOG_ROTATION_MAX_FILES=5

# =============================================================================
# CONFIGURACIÓN DE UPLOADS
# =============================================================================

# Directorio de uploads
UPLOAD_DIR=uploads

# Tamaño máximo de archivo (10MB)
MAX_FILE_SIZE=10485760

# Tipos de archivo permitidos
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# =============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# =============================================================================

# Ventana de tiempo para rate limiting
RATE_LIMIT_WINDOW=15m

# Número máximo de requests por ventana
RATE_LIMIT_MAX=100

# Mensaje de error para rate limit excedido
RATE_LIMIT_MESSAGE=Too many requests from this IP, please try again later.

# =============================================================================
# CONFIGURACIÓN DE EMAIL
# =============================================================================

# Servidor SMTP
SMTP_HOST=smtp.gmail.com

# Puerto SMTP
SMTP_PORT=587

# Usuario SMTP
SMTP_USER=your-email@gmail.com

# Contraseña SMTP
SMTP_PASS=your-app-password

# Email de remitente
SMTP_FROM=noreply@9001app.com

# Nombre del remitente
SMTP_FROM_NAME=9001app-v2

# =============================================================================
# CONFIGURACIÓN DE NOTIFICACIONES
# =============================================================================

# Habilitar notificaciones por email
NOTIFICATIONS_EMAIL_ENABLED=true

# Habilitar notificaciones push
NOTIFICATIONS_PUSH_ENABLED=false

# Habilitar notificaciones SMS
NOTIFICATIONS_SMS_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================================================

# Longitud mínima de contraseña
PASSWORD_MIN_LENGTH=8

# Requerir caracteres especiales en contraseña
PASSWORD_REQUIRE_SPECIAL_CHARS=true

# Requerir números en contraseña
PASSWORD_REQUIRE_NUMBERS=true

# Requerir mayúsculas en contraseña
PASSWORD_REQUIRE_UPPERCASE=true

# Número máximo de intentos de login
MAX_LOGIN_ATTEMPTS=5

# Tiempo de bloqueo después de intentos fallidos (en minutos)
LOGIN_LOCKOUT_TIME=15

# =============================================================================
# CONFIGURACIÓN DE SESSIONS
# =============================================================================

# Tiempo de expiración de sesión (en minutos)
SESSION_EXPIRES_IN=1440

# Clave secreta para sesiones
SESSION_SECRET=your-session-secret-key

# Almacenamiento de sesiones
SESSION_STORE=memory

# =============================================================================
# CONFIGURACIÓN DE CACHE
# =============================================================================

# Habilitar cache
CACHE_ENABLED=true

# Tiempo de expiración del cache (en segundos)
CACHE_TTL=3600

# Tamaño máximo del cache (en MB)
CACHE_MAX_SIZE=100

# =============================================================================
# CONFIGURACIÓN DE MONITORING
# =============================================================================

# Habilitar métricas
METRICS_ENABLED=true

# Puerto para métricas
METRICS_PORT=9090

# Endpoint para health check
HEALTH_CHECK_ENDPOINT=/health

# =============================================================================
# CONFIGURACIÓN DE BACKUP
# =============================================================================

# Habilitar backup automático
BACKUP_ENABLED=true

# Frecuencia de backup (en horas)
BACKUP_FREQUENCY=24

# Retención de backups (en días)
BACKUP_RETENTION=7

# Directorio de backup
BACKUP_DIR=backups

# =============================================================================
# CONFIGURACIÓN DE INTEGRACIONES
# =============================================================================

# API Key para servicios externos
EXTERNAL_API_KEY=your-external-api-key

# Webhook URL para notificaciones
WEBHOOK_URL=https://your-webhook-url.com/notifications

# =============================================================================
# CONFIGURACIÓN DE DESARROLLO
# =============================================================================

# Habilitar modo debug
DEBUG_MODE=true

# Mostrar errores detallados
SHOW_DETAILED_ERRORS=true

# Habilitar hot reload
HOT_RELOAD_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE PRODUCCIÓN
# =============================================================================

# Habilitar compresión
COMPRESSION_ENABLED=true

# Habilitar HTTPS
HTTPS_ENABLED=false

# Certificado SSL
SSL_CERT_PATH=/path/to/certificate.crt

# Clave privada SSL
SSL_KEY_PATH=/path/to/private.key

# =============================================================================
# CONFIGURACIÓN DE AGENTES
# =============================================================================

# Puerto del coordinador de agentes
AGENT_COORDINATOR_PORT=3001

# Host del coordinador de agentes
AGENT_COORDINATOR_HOST=localhost

# Número máximo de agentes
MAX_AGENTS=10

# Intervalo de heartbeat (en ms)
HEARTBEAT_INTERVAL=30000

# Timeout de tareas (en ms)
TASK_TIMEOUT=300000

# =============================================================================
# CONFIGURACIÓN DE FRONTEND
# =============================================================================

# URL de la API para el frontend
VITE_API_URL=http://localhost:5000/api

# Nombre de la aplicación
VITE_APP_NAME=9001app-v2

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Modo de desarrollo
VITE_DEV_MODE=true

# Modo de debug
VITE_DEBUG_MODE=true

# =============================================================================
# CONFIGURACIÓN DE ANALYTICS
# =============================================================================

# Google Analytics ID
VITE_ANALYTICS_ID=GA_MEASUREMENT_ID

# Habilitar analytics
VITE_ANALYTICS_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE FEATURES
# =============================================================================

# Habilitar búsqueda avanzada
FEATURE_ADVANCED_SEARCH=true

# Habilitar reportes
FEATURE_REPORTS=true

# Habilitar integraciones
FEATURE_INTEGRATIONS=false

# Habilitar sistema RAG
FEATURE_RAG_SYSTEM=true

# =============================================================================
# CONFIGURACIÓN DE LÍMITES
# =============================================================================

# Límite de organizaciones por usuario
LIMIT_ORGANIZATIONS_PER_USER=5

# Límite de usuarios por organización
LIMIT_USERS_PER_ORGANIZATION=100

# Límite de auditorías simultáneas
LIMIT_CONCURRENT_AUDITS=10

# Límite de documentos por organización
LIMIT_DOCUMENTS_PER_ORGANIZATION=1000

# =============================================================================
# CONFIGURACIÓN DE TIEMPO
# =============================================================================

# Zona horaria por defecto
DEFAULT_TIMEZONE=America/New_York

# Formato de fecha por defecto
DEFAULT_DATE_FORMAT=DD/MM/YYYY

# Formato de hora por defecto
DEFAULT_TIME_FORMAT=24h

# =============================================================================
# CONFIGURACIÓN DE IDIOMA
# =============================================================================

# Idioma por defecto
DEFAULT_LANGUAGE=es

# Idiomas disponibles
AVAILABLE_LANGUAGES=es,en,pt

# =============================================================================
# CONFIGURACIÓN DE MONEDA
# =============================================================================

# Moneda por defecto
DEFAULT_CURRENCY=USD

# Monedas disponibles
AVAILABLE_CURRENCIES=USD,EUR,ARS,BRL

# =============================================================================
# CONFIGURACIÓN DE REPORTES
# =============================================================================

# Formato de reportes por defecto
DEFAULT_REPORT_FORMAT=pdf

# Formatos de reporte disponibles
AVAILABLE_REPORT_FORMATS=pdf,excel,html

# Plantilla de reportes
REPORT_TEMPLATE_PATH=templates/reports

# =============================================================================
# CONFIGURACIÓN DE AUDITORÍA
# =============================================================================

# Habilitar auditoría de acciones
AUDIT_ENABLED=true

# Retención de logs de auditoría (en días)
AUDIT_RETENTION_DAYS=365

# Eventos a auditar
AUDIT_EVENTS=login,logout,create,update,delete,export

# =============================================================================
# CONFIGURACIÓN DE ENCRIPTACIÓN
# =============================================================================

# Algoritmo de encriptación
ENCRYPTION_ALGORITHM=aes-256-gcm

# Clave de encriptación
ENCRYPTION_KEY=your-32-character-encryption-key

# Vector de inicialización
ENCRYPTION_IV=your-16-character-iv

# =============================================================================
# CONFIGURACIÓN DE VALIDACIÓN
# =============================================================================

# Habilitar validación estricta
STRICT_VALIDATION=true

# Mostrar errores de validación detallados
DETAILED_VALIDATION_ERRORS=true

# Sanitizar inputs automáticamente
AUTO_SANITIZE_INPUTS=true

# =============================================================================
# CONFIGURACIÓN DE PERFORMANCE
# =============================================================================

# Habilitar compresión de respuestas
RESPONSE_COMPRESSION=true

# Tamaño de buffer para streams
STREAM_BUFFER_SIZE=8192

# Timeout de conexiones (en ms)
CONNECTION_TIMEOUT=30000

# Timeout de lectura (en ms)
READ_TIMEOUT=30000

# =============================================================================
# CONFIGURACIÓN DE TESTING
# =============================================================================

# Base de datos de testing
TEST_DATABASE_URL=mongodb+srv://test-user:test-pass@test-cluster.mongodb.net/9001app_v2_test

# Habilitar logs de testing
TEST_LOGGING_ENABLED=false

# Timeout de tests (en ms)
TEST_TIMEOUT=10000

# =============================================================================
# CONFIGURACIÓN DE DEPLOYMENT
# =============================================================================

# Entorno de deployment
DEPLOYMENT_ENV=development

# Versión de deployment
DEPLOYMENT_VERSION=1.0.0

# Build ID
BUILD_ID=build-123

# Commit hash
COMMIT_HASH=abc123def456

# =============================================================================
# CONFIGURACIÓN DE MONITORING EXTERNO
# =============================================================================

# Sentry DSN para error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# New Relic license key
NEW_RELIC_LICENSE_KEY=your-new-relic-license-key

# Datadog API key
DATADOG_API_KEY=your-datadog-api-key

# =============================================================================
# CONFIGURACIÓN DE REDES SOCIALES
# =============================================================================

# Facebook App ID
FACEBOOK_APP_ID=your-facebook-app-id

# Google Client ID
GOOGLE_CLIENT_ID=your-google-client-id

# LinkedIn Client ID
LINKEDIN_CLIENT_ID=your-linkedin-client-id

# =============================================================================
# CONFIGURACIÓN DE PAGOS
# =============================================================================

# Stripe public key
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key

# Stripe secret key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# PayPal client ID
PAYPAL_CLIENT_ID=your-paypal-client-id

# PayPal secret
PAYPAL_SECRET=your-paypal-secret

# =============================================================================
# CONFIGURACIÓN DE ALMACENAMIENTO
# =============================================================================

# Proveedor de almacenamiento
STORAGE_PROVIDER=local

# AWS S3 bucket
AWS_S3_BUCKET=your-s3-bucket

# AWS access key
AWS_ACCESS_KEY_ID=your-aws-access-key

# AWS secret key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# AWS region
AWS_REGION=us-east-1

# =============================================================================
# CONFIGURACIÓN DE CDN
# =============================================================================

# URL del CDN
CDN_URL=https://cdn.9001app.com

# Clave de API del CDN
CDN_API_KEY=your-cdn-api-key

# =============================================================================
# CONFIGURACIÓN DE WEBSOCKETS
# =============================================================================

# Habilitar WebSockets
WEBSOCKETS_ENABLED=true

# Puerto de WebSockets
WEBSOCKETS_PORT=3002

# =============================================================================
# CONFIGURACIÓN DE QUEUES
# =============================================================================

# Proveedor de colas
QUEUE_PROVIDER=redis

# URL de Redis
REDIS_URL=redis://localhost:6379

# =============================================================================
# CONFIGURACIÓN DE SEARCH
# =============================================================================

# Proveedor de búsqueda
SEARCH_PROVIDER=elasticsearch

# URL de Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# =============================================================================
# CONFIGURACIÓN DE IA/RAG
# =============================================================================

# Habilitar sistema RAG
RAG_SYSTEM_ENABLED=true

# OpenAI API key
OPENAI_API_KEY=your-openai-api-key

# Modelo de OpenAI
OPENAI_MODEL=gpt-4

# Temperatura del modelo
OPENAI_TEMPERATURE=0.7

# =============================================================================
# CONFIGURACIÓN DE NOTIFICACIONES PUSH
# =============================================================================

# VAPID public key
VAPID_PUBLIC_KEY=your-vapid-public-key

# VAPID private key
VAPID_PRIVATE_KEY=your-vapid-private-key

# =============================================================================
# CONFIGURACIÓN DE SMS
# =============================================================================

# Proveedor de SMS
SMS_PROVIDER=twilio

# Twilio account SID
TWILIO_ACCOUNT_SID=your-twilio-account-sid

# Twilio auth token
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Twilio phone number
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# CONFIGURACIÓN DE GEOCODING
# =============================================================================

# Google Maps API key
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# =============================================================================
# CONFIGURACIÓN DE WEATHER
# =============================================================================

# OpenWeatherMap API key
OPENWEATHER_API_KEY=your-openweather-api-key

# =============================================================================
# CONFIGURACIÓN DE CALENDAR
# =============================================================================

# Google Calendar API key
GOOGLE_CALENDAR_API_KEY=your-google-calendar-api-key

# =============================================================================
# CONFIGURACIÓN DE DOCUMENTOS
# =============================================================================

# Tamaño máximo de documento (en MB)
MAX_DOCUMENT_SIZE=50

# Formatos de documento permitidos
ALLOWED_DOCUMENT_FORMATS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt

# =============================================================================
# CONFIGURACIÓN DE IMÁGENES
# =============================================================================

# Tamaño máximo de imagen (en MB)
MAX_IMAGE_SIZE=10

# Formatos de imagen permitidos
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,gif,webp

# Calidad de compresión de imagen
IMAGE_COMPRESSION_QUALITY=80

# =============================================================================
# CONFIGURACIÓN DE VIDEOS
# =============================================================================

# Tamaño máximo de video (en MB)
MAX_VIDEO_SIZE=100

# Formatos de video permitidos
ALLOWED_VIDEO_FORMATS=mp4,avi,mov,wmv,flv

# =============================================================================
# CONFIGURACIÓN DE AUDIO
# =============================================================================

# Tamaño máximo de audio (en MB)
MAX_AUDIO_SIZE=20

# Formatos de audio permitidos
ALLOWED_AUDIO_FORMATS=mp3,wav,aac,ogg

# =============================================================================
# CONFIGURACIÓN DE ARCHIVOS
# =============================================================================

# Tamaño máximo de archivo comprimido (en MB)
MAX_ARCHIVE_SIZE=200

# Formatos de archivo comprimido permitidos
ALLOWED_ARCHIVE_FORMATS=zip,rar,7z,tar,gz

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD ADICIONAL
# =============================================================================

# Habilitar autenticación de dos factores
TWO_FACTOR_ENABLED=true

# Habilitar verificación de email
EMAIL_VERIFICATION_ENABLED=true

# Habilitar verificación de teléfono
PHONE_VERIFICATION_ENABLED=false

# Habilitar captcha
CAPTCHA_ENABLED=true

# Clave secreta de reCAPTCHA
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Clave del sitio de reCAPTCHA
RECAPTCHA_SITE_KEY=your-recaptcha-site-key

# =============================================================================
# CONFIGURACIÓN DE MANTENIMIENTO
# =============================================================================

# Modo de mantenimiento
MAINTENANCE_MODE=false

# Mensaje de mantenimiento
MAINTENANCE_MESSAGE=El sistema está en mantenimiento. Por favor, inténtelo más tarde.

# IPs permitidas durante mantenimiento
MAINTENANCE_ALLOWED_IPS=127.0.0.1,::1

# =============================================================================
# CONFIGURACIÓN DE DESARROLLO LOCAL
# =============================================================================

# Habilitar hot reload
HOT_RELOAD=true

# Puerto para hot reload
HOT_RELOAD_PORT=3003

# Habilitar proxy de desarrollo
DEV_PROXY_ENABLED=true

# URL del proxy de desarrollo
DEV_PROXY_URL=http://localhost:3000

# =============================================================================
# CONFIGURACIÓN DE TESTING LOCAL
# =============================================================================

# Base de datos de testing local
LOCAL_TEST_DB=mongodb://localhost:27017/9001app_v2_test

# Puerto para testing
TEST_PORT=5001

# Habilitar coverage de testing
TEST_COVERAGE_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE DOCKER
# =============================================================================

# Imagen de Docker
DOCKER_IMAGE=9001app-v2:latest

# Puerto de Docker
DOCKER_PORT=5000

# Volumen de Docker
DOCKER_VOLUME=/app/data

# =============================================================================
# CONFIGURACIÓN DE KUBERNETES
# =============================================================================

# Namespace de Kubernetes
K8S_NAMESPACE=9001app-v2

# Replicas de Kubernetes
K8S_REPLICAS=3

# Recursos de CPU
K8S_CPU_REQUEST=100m
K8S_CPU_LIMIT=500m

# Recursos de memoria
K8S_MEMORY_REQUEST=128Mi
K8S_MEMORY_LIMIT=512Mi

# =============================================================================
# CONFIGURACIÓN DE CI/CD
# =============================================================================

# URL del repositorio
REPO_URL=https://github.com/Sergiocharata1977/9001app-v2

# Rama por defecto
DEFAULT_BRANCH=main

# Habilitar auto-deploy
AUTO_DEPLOY_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE MONITORING
# =============================================================================

# URL de Grafana
GRAFANA_URL=http://localhost:3000

# URL de Prometheus
PROMETHEUS_URL=http://localhost:9090

# URL de Jaeger
JAEGER_URL=http://localhost:16686

# =============================================================================
# CONFIGURACIÓN DE LOGS
# =============================================================================

# Nivel de log para diferentes módulos
LOG_LEVEL_AUTH=info
LOG_LEVEL_DB=warn
LOG_LEVEL_API=info
LOG_LEVEL_AGENTS=debug

# Formato de timestamp
LOG_TIMESTAMP_FORMAT=YYYY-MM-DD HH:mm:ss

# Habilitar logs estructurados
STRUCTURED_LOGGING=true

# =============================================================================
# CONFIGURACIÓN DE MÉTRICAS
# =============================================================================

# Métricas de aplicación
METRICS_APP_ENABLED=true

# Métricas de base de datos
METRICS_DB_ENABLED=true

# Métricas de sistema
METRICS_SYSTEM_ENABLED=true

# Métricas de negocio
METRICS_BUSINESS_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE ALERTAS
# =============================================================================

# Habilitar alertas
ALERTS_ENABLED=true

# Email para alertas críticas
ALERTS_CRITICAL_EMAIL=admin@9001app.com

# Slack webhook para alertas
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# =============================================================================
# CONFIGURACIÓN DE BACKUP Y RECUPERACIÓN
# =============================================================================

# Habilitar backup automático
AUTO_BACKUP_ENABLED=true

# Frecuencia de backup (en horas)
BACKUP_INTERVAL=24

# Retención de backups (en días)
BACKUP_RETENTION_DAYS=30

# Compresión de backups
BACKUP_COMPRESSION=true

# Encriptación de backups
BACKUP_ENCRYPTION=true

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD AVANZADA
# =============================================================================

# Habilitar WAF (Web Application Firewall)
WAF_ENABLED=true

# Reglas de WAF
WAF_RULES_PATH=config/waf-rules.json

# Habilitar DDoS protection
DDOS_PROTECTION_ENABLED=true

# Límite de requests por IP
DDOS_RATE_LIMIT=100

# =============================================================================
# CONFIGURACIÓN DE COMPLIANCE
# =============================================================================

# Cumplimiento GDPR
GDPR_COMPLIANCE_ENABLED=true

# Cumplimiento HIPAA
HIPAA_COMPLIANCE_ENABLED=false

# Cumplimiento SOX
SOX_COMPLIANCE_ENABLED=false

# Cumplimiento PCI DSS
PCI_COMPLIANCE_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE LOCALIZACIÓN
# =============================================================================

# Región por defecto
DEFAULT_REGION=US

# Zona horaria por defecto
DEFAULT_TIMEZONE=America/New_York

# Formato de números
NUMBER_FORMAT=en-US

# Formato de moneda
CURRENCY_FORMAT=en-US

# =============================================================================
# CONFIGURACIÓN DE ACCESIBILIDAD
# =============================================================================

# Habilitar características de accesibilidad
ACCESSIBILITY_ENABLED=true

# Soporte para lectores de pantalla
SCREEN_READER_SUPPORT=true

# Alto contraste
HIGH_CONTRAST_MODE=false

# Tamaño de fuente aumentable
SCALABLE_FONT_SIZE=true

# =============================================================================
# CONFIGURACIÓN DE INTERNACIONALIZACIÓN
# =============================================================================

# Idiomas soportados
SUPPORTED_LANGUAGES=es,en,pt,fr,de

# Traducciones automáticas
AUTO_TRANSLATION_ENABLED=false

# Proveedor de traducción
TRANSLATION_PROVIDER=google

# API key de traducción
TRANSLATION_API_KEY=your-translation-api-key

# =============================================================================
# CONFIGURACIÓN DE GAMIFICACIÓN
# =============================================================================

# Habilitar gamificación
GAMIFICATION_ENABLED=true

# Sistema de puntos
POINTS_SYSTEM_ENABLED=true

# Sistema de badges
BADGES_SYSTEM_ENABLED=true

# Sistema de leaderboards
LEADERBOARDS_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE COLABORACIÓN
# =============================================================================

# Habilitar colaboración en tiempo real
REAL_TIME_COLLABORATION=true

# Compartir documentos
DOCUMENT_SHARING_ENABLED=true

# Comentarios en tiempo real
REAL_TIME_COMMENTS=true

# Edición colaborativa
COLLABORATIVE_EDITING=true

# =============================================================================
# CONFIGURACIÓN DE INTEGRACIÓN
# =============================================================================

# Integración con Slack
SLACK_INTEGRATION_ENABLED=false
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret

# Integración con Microsoft Teams
TEAMS_INTEGRATION_ENABLED=false
TEAMS_CLIENT_ID=your-teams-client-id
TEAMS_CLIENT_SECRET=your-teams-client-secret

# Integración con Zoom
ZOOM_INTEGRATION_ENABLED=false
ZOOM_CLIENT_ID=your-zoom-client-id
ZOOM_CLIENT_SECRET=your-zoom-client-secret

# =============================================================================
# CONFIGURACIÓN DE AUTOMATIZACIÓN
# =============================================================================

# Habilitar automatización de tareas
TASK_AUTOMATION_ENABLED=true

# Workflows automáticos
AUTOMATED_WORKFLOWS_ENABLED=true

# Triggers automáticos
AUTOMATED_TRIGGERS_ENABLED=true

# Escalación automática
AUTOMATED_ESCALATION_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE REPORTING
# =============================================================================

# Reportes automáticos
AUTOMATED_REPORTS_ENABLED=true

# Frecuencia de reportes (en días)
REPORT_FREQUENCY=7

# Formato de reportes por defecto
DEFAULT_REPORT_FORMAT=pdf

# Plantillas de reportes
REPORT_TEMPLATES_PATH=templates/reports

# =============================================================================
# CONFIGURACIÓN DE DASHBOARDS
# =============================================================================

# Dashboards personalizables
CUSTOM_DASHBOARDS_ENABLED=true

# Widgets disponibles
AVAILABLE_WIDGETS=audits,training,documents,users,reports

# Layouts de dashboard
DASHBOARD_LAYOUTS=grid,list,kanban

# =============================================================================
# CONFIGURACIÓN DE MOBILE
# =============================================================================

# Soporte móvil
MOBILE_SUPPORT_ENABLED=true

# App nativa
NATIVE_APP_ENABLED=false

# PWA (Progressive Web App)
PWA_ENABLED=true

# Push notifications móviles
MOBILE_PUSH_NOTIFICATIONS=true

# =============================================================================
# CONFIGURACIÓN DE API
# =============================================================================

# Versión de API
API_VERSION=v1

# Rate limiting por API key
API_RATE_LIMIT_PER_KEY=1000

# Documentación de API
API_DOCS_ENABLED=true

# Swagger UI
SWAGGER_UI_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE WEBHOOKS
# =============================================================================

# Webhooks habilitados
WEBHOOKS_ENABLED=true

# Número máximo de webhooks por organización
MAX_WEBHOOKS_PER_ORG=10

# Timeout de webhooks (en ms)
WEBHOOK_TIMEOUT=30000

# Reintentos de webhooks
WEBHOOK_RETRY_ATTEMPTS=3

# =============================================================================
# CONFIGURACIÓN DE BATCH PROCESSING
# =============================================================================

# Procesamiento por lotes
BATCH_PROCESSING_ENABLED=true

# Tamaño de lote por defecto
DEFAULT_BATCH_SIZE=100

# Timeout de procesamiento por lotes (en ms)
BATCH_PROCESSING_TIMEOUT=300000

# Paralelismo de procesamiento
BATCH_PARALLELISM=5

# =============================================================================
# CONFIGURACIÓN DE SCHEDULING
# =============================================================================

# Programación de tareas
TASK_SCHEDULING_ENABLED=true

# Cron jobs habilitados
CRON_JOBS_ENABLED=true

# Tareas programadas
SCHEDULED_TASKS=backup,cleanup,reports,notifications

# =============================================================================
# CONFIGURACIÓN DE CACHE DISTRIBUIDO
# =============================================================================

# Cache distribuido
DISTRIBUTED_CACHE_ENABLED=true

# Proveedor de cache distribuido
DISTRIBUTED_CACHE_PROVIDER=redis

# TTL del cache distribuido (en segundos)
DISTRIBUTED_CACHE_TTL=3600

# =============================================================================
# CONFIGURACIÓN DE LOAD BALANCING
# =============================================================================

# Load balancing
LOAD_BALANCING_ENABLED=true

# Algoritmo de load balancing
LOAD_BALANCING_ALGORITHM=round-robin

# Health check interval (en ms)
HEALTH_CHECK_INTERVAL=30000

# =============================================================================
# CONFIGURACIÓN DE AUTO-SCALING
# =============================================================================

# Auto-scaling
AUTO_SCALING_ENABLED=true

# Métrica de escalado
SCALING_METRIC=cpu

# Umbral de escalado hacia arriba
SCALE_UP_THRESHOLD=80

# Umbral de escalado hacia abajo
SCALE_DOWN_THRESHOLD=20

# =============================================================================
# CONFIGURACIÓN DE DISASTER RECOVERY
# =============================================================================

# Recuperación ante desastres
DISASTER_RECOVERY_ENABLED=true

# RTO (Recovery Time Objective) en minutos
RTO_MINUTES=60

# RPO (Recovery Point Objective) en minutos
RPO_MINUTES=15

# Sitio de recuperación
RECOVERY_SITE_URL=https://dr.9001app.com

# =============================================================================
# CONFIGURACIÓN DE COMPLIANCE Y AUDITORÍA
# =============================================================================

# Auditoría de compliance
COMPLIANCE_AUDIT_ENABLED=true

# Retención de logs de auditoría (en años)
AUDIT_LOG_RETENTION_YEARS=7

# Encriptación de logs de auditoría
AUDIT_LOG_ENCRYPTION=true

# =============================================================================
# CONFIGURACIÓN DE PRIVACIDAD
# =============================================================================

# Política de privacidad
PRIVACY_POLICY_ENABLED=true

# Consentimiento de cookies
COOKIE_CONSENT_ENABLED=true

# Anonimización de datos
DATA_ANONYMIZATION_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE ACCESO
# =============================================================================

# Control de acceso basado en roles
RBAC_ENABLED=true

# Permisos granulares
GRANULAR_PERMISSIONS_ENABLED=true

# Jerarquía de roles
ROLE_HIERARCHY_ENABLED=true

# =============================================================================
# CONFIGURACIÓN DE NOTIFICACIONES AVANZADAS
# =============================================================================

# Notificaciones inteligentes
INTELLIGENT_NOTIFICATIONS_ENABLED=true

# Personalización de notificaciones
NOTIFICATION_PERSONALIZATION=true

# Programación de notificaciones
NOTIFICATION_SCHEDULING=true

# =============================================================================
# CONFIGURACIÓN DE BÚSQUEDA AVANZADA
# =============================================================================

# Búsqueda semántica
SEMANTIC_SEARCH_ENABLED=true

# Búsqueda por voz
VOICE_SEARCH_ENABLED=false

# Búsqueda de imágenes
IMAGE_SEARCH_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE IA Y ML
# =============================================================================

# Machine Learning
ML_ENABLED=true

# Predicciones automáticas
AUTOMATIC_PREDICTIONS=true

# Recomendaciones inteligentes
INTELLIGENT_RECOMMENDATIONS=true

# =============================================================================
# CONFIGURACIÓN DE BLOCKCHAIN
# =============================================================================

# Integración con blockchain
BLOCKCHAIN_INTEGRATION_ENABLED=false

# Smart contracts
SMART_CONTRACTS_ENABLED=false

# NFTs
NFT_SUPPORT_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE REALIDAD AUMENTADA
# =============================================================================

# Realidad aumentada
AR_ENABLED=false

# Visualización AR
AR_VISUALIZATION_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE REALIDAD VIRTUAL
# =============================================================================

# Realidad virtual
VR_ENABLED=false

# Entornos VR
VR_ENVIRONMENTS_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE INTERNET DE LAS COSAS
# =============================================================================

# IoT habilitado
IOT_ENABLED=false

# Sensores IoT
IOT_SENSORS_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE EDGE COMPUTING
# =============================================================================

# Edge computing
EDGE_COMPUTING_ENABLED=false

# Procesamiento en el edge
EDGE_PROCESSING_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE QUANTUM COMPUTING
# =============================================================================

# Quantum computing
QUANTUM_COMPUTING_ENABLED=false

# Algoritmos cuánticos
QUANTUM_ALGORITHMS_ENABLED=false

# =============================================================================
# CONFIGURACIÓN DE FUTURO
# =============================================================================

# Características experimentales
EXPERIMENTAL_FEATURES_ENABLED=false

# Modo beta
BETA_MODE_ENABLED=false

# Características de preview
PREVIEW_FEATURES_ENABLED=false

# =============================================================================
# FIN DE CONFIGURACIÓN
# =============================================================================
# 
# IMPORTANTE: 
# 1. Cambia todas las claves secretas y contraseñas antes de usar en producción
# 2. Configura las variables según tu entorno específico
# 3. Revisa y ajusta los límites según tus necesidades
# 4. Mantén este archivo seguro y no lo subas al control de versiones
# 5. Usa diferentes valores para desarrollo, staging y producción
#
# Para más información, consulta la documentación en:
# https://docs.9001app.com/configuration
#
# =============================================================================